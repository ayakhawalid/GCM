<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane style="-fx-background-color: #f5f6fa;" stylesheets="@sidebar.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.boundary.AdminCustomersScreen">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 20; -fx-border-color: #e7e7e7; -fx-border-width: 0 0 1 0;">
            <Button onAction="#handleBack" onMouseEntered="#handleBackHoverEnter" onMouseExited="#handleBackHoverExit" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 10; -fx-padding: 6 10;" text="← Back" />
            <Button onAction="#toggleGuestDashboard" style="-fx-background-color: #d5ed9f; -fx-text-fill: #00712d; -fx-font-family: 'Segoe UI', 'Trebuchet MS', sans-serif; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 6 14; -fx-cursor: hand;" text="Menu" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="5">
                <WebView fx:id="navbarLogoView1" contextMenuEnabled="false" maxHeight="30" maxWidth="30" minHeight="30" minWidth="30" prefHeight="30" prefWidth="30" />
                <Button onAction="#navigateToHome" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: black; -fx-font-family: 'Trebuchet MS', 'Segoe UI', sans-serif; -fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 2 0 2;" text="Global City Map" />
            </HBox>
        </HBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <HBox spacing="0">
            <VBox fx:id="guestDashboardPane" managed="false" maxWidth="260" prefWidth="260" spacing="0" style="-fx-background-color: white; -fx-border-color: #e3e3e3; -fx-border-width: 0 1 0 0;" visible="false">
                <VBox spacing="0" style="-fx-padding: 0;">
                    <Button maxWidth="1.7976931348623157E308" onAction="#openSearchScreenFromAction" styleClass="sidebar-nav-btn" text="Browse Catalog" />
                    <Button fx:id="mapEditorNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openMapEditorFromMenu" styleClass="sidebar-nav-btn" text="Map Editor" visible="false" />
                    <Button fx:id="myPurchasesNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openMyPurchasesFromMenu" styleClass="sidebar-nav-btn" text="My Purchases" visible="false" />
                    <Button fx:id="profileNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openProfileFromMenu" styleClass="sidebar-nav-btn" text="My Profile" visible="false" />
                    <Button fx:id="customersNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openAdminCustomersFromMenu" styleClass="sidebar-nav-btn" text="Customers" visible="false" />
                    <Button fx:id="pricingNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openPricingFromMenu" styleClass="sidebar-nav-btn" text="Pricing" visible="false" />
                    <Button fx:id="pricingApprovalNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openPricingApprovalFromMenu" styleClass="sidebar-nav-btn" text="Approve Prices" visible="false" />
                    <Button fx:id="supportNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openSupportFromMenu" styleClass="sidebar-nav-btn" text="Support" visible="false" />
                    <Button fx:id="agentConsoleNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openAgentConsoleFromMenu" styleClass="sidebar-nav-btn" text="Agent Console" visible="false" />
                    <Button fx:id="editApprovalsNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openEditApprovalsFromMenu" styleClass="sidebar-nav-btn" text="Edit Approvals" visible="false" />
                    <Button fx:id="reportsNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openReportsFromMenu" styleClass="sidebar-nav-btn" text="City Reports" visible="false" />
                    <Button fx:id="userManagementNavBtn" managed="false" maxWidth="1.7976931348623157E308" onAction="#openUserManagementFromMenu" styleClass="sidebar-nav-btn" text="User Management" visible="false" />
                </VBox>
            </VBox>
            <VBox spacing="20" style="-fx-padding: 25; -fx-background-color: #f5f6fa;" HBox.hgrow="ALWAYS">
            
            <!-- Stats Cards -->
            <HBox spacing="20">
                <VBox alignment="CENTER" prefHeight="118.0" prefWidth="250.0" spacing="5" style="-fx-background-color: #27ae60; -fx-background-radius: 15; -fx-padding: 20;">
                    <Label fx:id="totalCustomersLabel" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" text="0" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px;" text="Total Customers" />
                </VBox>
                <VBox alignment="CENTER" prefHeight="100" prefWidth="200" spacing="5" style="-fx-background-color: #27ae60; -fx-background-radius: 15; -fx-padding: 20; -fx-pref-width: 250;">
                    <Label fx:id="totalRevenueLabel" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" text="0" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px;" text="Total Revenue" />
                </VBox>
                <VBox alignment="CENTER" prefHeight="100" prefWidth="200" spacing="5" style="-fx-background-color: #27ae60; -fx-background-radius: 15; -fx-padding: 20; -fx-pref-width: 250;">
                    <Label fx:id="avgSpendLabel" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" text="0" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px;" text="Avg. per Customer" />
                </VBox>
            </HBox>
            
            <!-- Search and Actions -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <TextField fx:id="searchField" prefWidth="300" promptText="Search customers..." style="-fx-background-color: white; -fx-text-fill: #2c3e50; -fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" />
                <Button onAction="#handleSearch" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 5;" text="Search" />
                <Region HBox.hgrow="ALWAYS" />
                <CheckBox fx:id="lastMonthCheck" onAction="#handleRefresh" style="-fx-text-fill: #2c3e50;" text="Last 1 Month Only" />
                <Button onAction="#handleRefresh" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 5;" text="🔄 Refresh" />
            </HBox>
            
            <!-- Customers Table -->
            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <Label style="-fx-text-fill: #2c3e50; -fx-font-size: 18px; -fx-font-weight: bold;" text="All Customers" />
                
                <TableView fx:id="customersTable" style="-fx-background-color: #ecf0f1; -fx-control-inner-background: white;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="usernameCol" prefWidth="150" text="Username" />
                        <TableColumn fx:id="emailCol" prefWidth="200" text="Email" />
                        <TableColumn fx:id="phoneCol" prefWidth="130" text="Phone" />
                        <TableColumn fx:id="purchasesCol" prefWidth="90" text="Purchases" />
                        <TableColumn fx:id="subscriptionsCol" prefWidth="70" text="Subs" />
                        <TableColumn fx:id="spentCol" prefWidth="120" text="Total Spent" />
                        <TableColumn fx:id="registeredCol" prefWidth="120" text="Registered" />
                        <TableColumn fx:id="statusCol" prefWidth="80" text="Status" />
                        <TableColumn fx:id="actionCol" prefWidth="100" text="Action" />
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill: #7f8c8d;" text="No customers found" />
                    </placeholder>
                </TableView>
            </VBox>
            
            <!-- Customer Purchases Panel (shown when a customer is selected) -->
            <VBox fx:id="purchasesPanel" managed="false" spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-border-color: #ddd; -fx-border-radius: 10; -fx-border-width: 1;" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label fx:id="selectedCustomerLabel" style="-fx-text-fill: #2c3e50; -fx-font-size: 16px; -fx-font-weight: bold;" text="Customer Purchases" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#closePurchasesPanel" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 5 15; -fx-background-radius: 5;" text="Close" />
                </HBox>
                
                <TableView fx:id="purchasesTable" prefHeight="200" style="-fx-background-color: #ecf0f1; -fx-control-inner-background: white;">
                    <columns>
                        <TableColumn fx:id="pCityCol" prefWidth="180" text="City" />
                        <TableColumn fx:id="pTypeCol" prefWidth="120" text="Type" />
                        <TableColumn fx:id="pPriceCol" prefWidth="100" text="Price" />
                        <TableColumn fx:id="pDateCol" prefWidth="130" text="Date" />
                        <TableColumn fx:id="pStatusCol" prefWidth="100" text="Status" />
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
        </HBox>
    </center>
    
    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #ecf0f1; -fx-padding: 10;">
            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Admin Panel" />
            <Label style="-fx-text-fill: #7f8c8d;" text="•" />
            <Label fx:id="statusLabel" style="-fx-text-fill: #27ae60; -fx-font-size: 11px;" text="Ready" />
        </HBox>
    </bottom>
</BorderPane>
