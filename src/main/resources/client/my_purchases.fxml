<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.web.WebView?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="client.boundary.MyPurchasesScreen"
      spacing="0"
      style="-fx-background-color: #f5f6fa;" stylesheets="@sidebar.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 20; -fx-border-color: #e7e7e7; -fx-border-width: 0 0 1 0;">
        <Button onAction="#handleBack" onMouseEntered="#handleBackHoverEnter" onMouseExited="#handleBackHoverExit" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 10; -fx-padding: 6 10;" text="← Back" />
        <Button onAction="#toggleGuestDashboard" style="-fx-background-color: #d5ed9f; -fx-text-fill: #00712d; -fx-font-family: 'Segoe UI', 'Trebuchet MS', sans-serif; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 6 14; -fx-cursor: hand;" text="Menu" />
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER_RIGHT" spacing="5">
            <WebView fx:id="navbarLogoView1" maxHeight="30" maxWidth="30" minHeight="30" minWidth="30" prefHeight="30" prefWidth="30" />
            <Button onAction="#navigateToHome" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: black; -fx-font-family: 'Trebuchet MS', 'Segoe UI', sans-serif; -fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 2 0 2;" text="Global City Map" />
        </HBox>
    </HBox>

    <HBox spacing="0" VBox.vgrow="ALWAYS">
        <VBox fx:id="guestDashboardPane" managed="false" maxWidth="260" prefWidth="260" spacing="0" style="-fx-background-color: white; -fx-border-color: #e3e3e3; -fx-border-width: 0 1 0 0;" visible="false">
            <VBox spacing="0" style="-fx-padding: 0;">
                <Button styleClass="sidebar-nav-btn" text="Browse Catalog" onAction="#openSearchScreenFromAction" maxWidth="1.7976931348623157E308"/>
                <Button fx:id="mapEditorNavBtn" styleClass="sidebar-nav-btn" text="Map Editor" onAction="#openMapEditorFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="myPurchasesNavBtn" styleClass="sidebar-nav-btn" text="My Purchases" onAction="#openMyPurchasesFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="profileNavBtn" styleClass="sidebar-nav-btn" text="My Profile" onAction="#openProfileFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="customersNavBtn" styleClass="sidebar-nav-btn" text="Customers" onAction="#openAdminCustomersFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="pricingNavBtn" styleClass="sidebar-nav-btn" text="Pricing" onAction="#openPricingFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="pricingApprovalNavBtn" styleClass="sidebar-nav-btn" text="Approve Prices" onAction="#openPricingApprovalFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="supportNavBtn" styleClass="sidebar-nav-btn" text="Support" onAction="#openSupportFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="agentConsoleNavBtn" styleClass="sidebar-nav-btn" text="Agent Console" onAction="#openAgentConsoleFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="editApprovalsNavBtn" styleClass="sidebar-nav-btn" text="Edit Approvals" onAction="#openEditApprovalsFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="reportsNavBtn" styleClass="sidebar-nav-btn" text="City Reports" onAction="#openReportsFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                <Button fx:id="userManagementNavBtn" styleClass="sidebar-nav-btn" text="User Management" onAction="#openUserManagementFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
            </VBox>
        </VBox>
        <VBox spacing="15" style="-fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label fx:id="statusLabel" text="" style="-fx-text-fill: #27ae60;"/>

            <Separator/>

            <!-- Subscriptions Section -->
            <VBox spacing="10">
                <Label text="Active Subscriptions" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                <Label text="View all city maps for these cities. Subscriptions include unlimited viewing and downloading." 
                       style="-fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>
                
                <TableView fx:id="subscriptionsTable" VBox.vgrow="ALWAYS" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="subCityCol" text="City" prefWidth="200"/>
                        <TableColumn fx:id="subStatusCol" text="Status" prefWidth="100"/>
                        <TableColumn fx:id="subExpiryCol" text="Expires On" prefWidth="150"/>
                        <TableColumn fx:id="subActionCol" text="Actions" prefWidth="150"/>
                    </columns>
                    <placeholder>
                        <Label text="No active subscriptions found."/>
                    </placeholder>
                </TableView>
            </VBox>
            
            <Separator/>

            <!-- One-Time Purchases Section -->
            <VBox spacing="10">
                <Label text="One-Time Purchases" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                <Label text="Purchase history per city. Open the maps viewer from the catalog after purchase; download is demo-only (⬇)." 
                       style="-fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>
                
                <TableView fx:id="purchasesTable" VBox.vgrow="ALWAYS" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="purchaseCityCol" text="City" prefWidth="200"/>
                        <TableColumn fx:id="purchaseDateCol" text="Purchased Date" prefWidth="150"/>
                    </columns>
                    <placeholder>
                        <Label text="No one-time purchases found."/>
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </HBox>

</VBox>
