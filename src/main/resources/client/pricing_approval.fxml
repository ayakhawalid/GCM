<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.web.WebView?>

<BorderPane fx:id="rootPane" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.boundary.PricingApprovalScreen"
            stylesheets="@sidebar.css">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 20; -fx-border-color: #e7e7e7; -fx-border-width: 0 0 1 0;">
            <Button onAction="#handleBack" onMouseEntered="#handleBackHoverEnter" onMouseExited="#handleBackHoverExit" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 10; -fx-padding: 6 10;" text="← Back" />
            <Button onAction="#toggleGuestDashboard" style="-fx-background-color: #d5ed9f; -fx-text-fill: #00712d; -fx-font-family: 'Segoe UI', 'Trebuchet MS', sans-serif; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 6 14; -fx-cursor: hand;" text="Menu" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="5">
                <WebView fx:id="navbarLogoView1" maxHeight="30" maxWidth="30" minHeight="30" minWidth="30" prefHeight="30" prefWidth="30" />
                <Button onAction="#navigateToHome" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: black; -fx-font-family: 'Trebuchet MS', 'Segoe UI', sans-serif; -fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 2 0 2;" text="Global City Map" />
            </HBox>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <HBox spacing="0" style="-fx-background-color: #f5f6fa;">
            <VBox fx:id="guestDashboardPane" managed="false" minWidth="260" maxWidth="260" prefWidth="260" spacing="0" style="-fx-background-color: white; -fx-border-color: #e3e3e3; -fx-border-width: 0 1 0 0;" visible="false">
                <VBox spacing="0" style="-fx-padding: 0;">
                    <Button styleClass="sidebar-nav-btn" text="Browse Catalog" onAction="#openSearchScreenFromAction" maxWidth="1.7976931348623157E308"/>
                    <Button fx:id="mapEditorNavBtn" styleClass="sidebar-nav-btn" text="Map Editor" onAction="#openMapEditorFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="myPurchasesNavBtn" styleClass="sidebar-nav-btn" text="My Purchases" onAction="#openMyPurchasesFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="profileNavBtn" styleClass="sidebar-nav-btn" text="My Profile" onAction="#openProfileFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="customersNavBtn" styleClass="sidebar-nav-btn" text="Customers" onAction="#openAdminCustomersFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="pricingNavBtn" styleClass="sidebar-nav-btn" text="Pricing" onAction="#openPricingFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="pricingApprovalNavBtn" styleClass="sidebar-nav-btn" text="Approve Prices" onAction="#openPricingApprovalFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="supportNavBtn" styleClass="sidebar-nav-btn" text="Support" onAction="#openSupportFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="agentConsoleNavBtn" styleClass="sidebar-nav-btn" text="Agent Console" onAction="#openAgentConsoleFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="editApprovalsNavBtn" styleClass="sidebar-nav-btn" text="Edit Approvals" onAction="#openEditApprovalsFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="reportsNavBtn" styleClass="sidebar-nav-btn" text="City Reports" onAction="#openReportsFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="userManagementNavBtn" styleClass="sidebar-nav-btn" text="User Management" onAction="#openUserManagementFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                </VBox>
            </VBox>
            <HBox spacing="20" style="-fx-padding: 20;" HBox.hgrow="ALWAYS">
            
            <!-- Left: Pending Requests Table (white theme, border between rows) -->
            <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20; -fx-border-color: #e9ecef; -fx-border-width: 1; -fx-border-radius: 8;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Pending Pricing Requests" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                    <Button text="Refresh" onAction="#refreshRequests"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>
                
                <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS" styleClass="approval-table"
                           style="-fx-background-color: white; -fx-background-radius: 8; -fx-control-inner-background: white; -fx-control-inner-background-alt: white;">
                    <columns>
                        <TableColumn fx:id="cityCol" text="City" prefWidth="140"/>
                        <TableColumn fx:id="currentCol" text="Current" prefWidth="90"/>
                        <TableColumn fx:id="proposedCol" text="Proposed" prefWidth="90"/>
                        <TableColumn fx:id="changeCol" text="Change" prefWidth="80"/>
                        <TableColumn fx:id="submitterCol" text="Submitted By" prefWidth="120"/>
                        <TableColumn fx:id="dateCol" text="Date" prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <Label text="No pending pricing requests" style="-fx-text-fill: #95a5a6;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- Right: Request Details Panel -->
            <VBox spacing="20" prefWidth="380" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                <Label text="Request Details" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
                
                <!-- City Info -->
                <VBox spacing="8" style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="City:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                    <Label fx:id="detailCityLabel" text="(Select a request)" 
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
                </VBox>

                <!-- Price Change -->
                <HBox spacing="20" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #ffebee; -fx-background-radius: 8; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                        <Label text="Current Price" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        <Label fx:id="detailCurrentLabel" text="₪0.00" 
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
                    </VBox>
                    <Label text="→" style="-fx-font-size: 24px; -fx-text-fill: #95a5a6;"/>
                    <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #e8f5e9; -fx-background-radius: 8; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                        <Label text="Proposed Price" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        <Label fx:id="detailProposedLabel" text="₪0.00" 
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                    </VBox>
                </HBox>

                <!-- Change Percentage -->
                <HBox alignment="CENTER">
                    <Label fx:id="detailChangeLabel" text="" 
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 20;"/>
                </HBox>

                <!-- Submitter Info -->
                <VBox spacing="5">
                    <Label text="Submitted By:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                    <Label fx:id="detailSubmitterLabel" text="-" 
                           style="-fx-font-size: 14px; -fx-text-fill: #2d3436;"/>
                </VBox>

                <!-- Reason -->
                <VBox spacing="5" VBox.vgrow="ALWAYS">
                    <Label text="Reason for Change:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                    <TextArea fx:id="detailReasonArea" editable="false" wrapText="true"
                              VBox.vgrow="ALWAYS"
                              style="-fx-background-color: #f8f9fa; -fx-border-color: transparent;"/>
                </VBox>

                <!-- Action Buttons -->
                <HBox spacing="15">
                    <Button fx:id="approveBtn" text="Approve" onAction="#handleApprove"
                            HBox.hgrow="ALWAYS" prefWidth="150"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button fx:id="rejectBtn" text="Reject" onAction="#handleReject"
                            HBox.hgrow="ALWAYS" prefWidth="150"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" wrapText="true"/>
            </VBox>
            </HBox>
        </HBox>
    </center>

</BorderPane>
