<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.boundary.ProfileScreen">
    
    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 15 25;">
            <Button fx:id="backBtn" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: #111111; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6 10; -fx-background-radius: 10;" text="← Back" />
         <Button onAction="#toggleGuestDashboard" style="-fx-background-color: #d5ed9f; -fx-text-fill: #00712d; -fx-font-family: 'Segoe UI', 'Trebuchet MS', sans-serif; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 6 14; -fx-cursor: hand;" text="Menu" />
            <Region prefHeight="32.0" prefWidth="344.0" HBox.hgrow="ALWAYS" />
            <Label fx:id="userInfoLabel" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;" text="" />
         <HBox alignment="CENTER_RIGHT" spacing="8">
            <children>
               <WebView fx:id="navbarLogoView1" contextMenuEnabled="false" maxHeight="30" maxWidth="30" minHeight="30" minWidth="30" prefHeight="30" prefWidth="30" />
               <Label style="-fx-text-fill: black; -fx-font-family: 'Trebuchet MS', 'Segoe UI', sans-serif; -fx-font-size: 24px; -fx-font-weight: bold;" text="Global City Map" />
            </children>
         </HBox>
        </HBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <HBox spacing="0">
            <!-- Left vertical menu -->
            <VBox fx:id="guestDashboardPane" managed="false" maxWidth="260" prefWidth="260" spacing="0" style="-fx-background-color: white; -fx-border-color: #e3e3e3; -fx-border-width: 0 1 0 0;" visible="false">
                <VBox spacing="0" style="-fx-padding: 8 0;">
                    <Button text="Browse Catalog" onAction="#openSearchScreenFromAction" maxWidth="1.7976931348623157E308" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="mapEditorNavBtn" text="Map Editor" onAction="#openMapEditorFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="myPurchasesNavBtn" text="My Purchases" onAction="#openMyPurchasesFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="profileNavBtn" text="My Profile" onAction="#openProfileFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="customersNavBtn" text="Customers" onAction="#openAdminCustomersFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="pricingNavBtn" text="Pricing" onAction="#openPricingFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="pricingApprovalNavBtn" text="Approve Prices" onAction="#openPricingApprovalFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="supportNavBtn" text="Support" onAction="#openSupportFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="agentConsoleNavBtn" text="Agent Console" onAction="#openAgentConsoleFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="editApprovalsNavBtn" text="Edit Approvals" onAction="#openEditApprovalsFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="reportsNavBtn" text="City Reports" onAction="#openReportsFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="userManagementNavBtn" text="User Management" onAction="#openUserManagementFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                </VBox>
            </VBox>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f5f6fa;" HBox.hgrow="ALWAYS">
            <VBox spacing="25" style="-fx-padding: 30; -fx-background-color: #f5f6fa;">
                
                <!-- Profile Card -->
                <VBox spacing="20" style="-fx-background-color: #ecf0f1; -fx-background-radius: 15; -fx-padding: 25;">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label style="-fx-font-size: 48px;" text="👤" />
                        <VBox spacing="5">
                            <Label fx:id="usernameLabel" style="-fx-text-fill: #2c3e50; -fx-font-size: 24px; -fx-font-weight: bold;" text="Username" />
                            <Label fx:id="memberSinceLabel" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Member since: ---" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #dfe6e9; -fx-background-radius: 10; -fx-padding: 15;">
                            <Label fx:id="totalPurchasesLabel" style="-fx-text-fill: #667eea; -fx-font-size: 24px; -fx-font-weight: bold;" text="0" />
                            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Purchases" />
                        </VBox>
                        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #dfe6e9; -fx-background-radius: 10; -fx-padding: 15;">
                            <Label fx:id="totalSpentLabel" style="-fx-text-fill: #27ae60; -fx-font-size: 24px; -fx-font-weight: bold;" text="0" />
                            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Total Spent" />
                        </VBox>
                    </HBox>
                    
                    <Separator style="-fx-background-color: #bdc3c7;" />
                    
                    <!-- Profile Form -->
                    <GridPane hgap="20" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="120" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                            <ColumnConstraints halignment="RIGHT" minWidth="120" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                        </columnConstraints>
                        
                        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="emailField" promptText="your@email.com" style="-fx-background-color: white; -fx-text-fill: #2c3e50; -fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" text="Phone:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <TextField fx:id="phoneField" promptText="+1 234 567 8900" style="-fx-background-color: white; -fx-text-fill: #2c3e50; -fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 5;" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                        
                        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" text="Card:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <HBox alignment="CENTER_LEFT" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label fx:id="cardLabel" style="-fx-text-fill: #2c3e50; -fx-font-size: 14px; -fx-font-family: 'Consolas';" text="No saved credit card" />
                            <Button fx:id="removeCardBtn" onAction="#handleRemoveCard" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 3 8; -fx-background-radius: 3;" text="Remove Saved Card" />
                        </HBox>
                        
                        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" text="Last Login:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <Label fx:id="lastLoginLabel" style="-fx-text-fill: #2c3e50; -fx-font-size: 14px;" text="---" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>
                    
                    <!-- Save Button -->
                    <HBox alignment="CENTER_RIGHT" spacing="15">
                        <Label fx:id="statusLabel" style="-fx-font-size: 12px;" text="" />
                        <Button fx:id="saveBtn" onAction="#handleSaveProfile" style="-fx-background-color: #00712d; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 25; -fx-background-radius: 5;" text="💾 Save Changes" />
                    </HBox>
                </VBox>
                
                <!-- Purchase History Section -->
                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label style="-fx-text-fill: #2c3e50; -fx-font-size: 20px; -fx-font-weight: bold;" text="📦 Purchase History" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleRefresh" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8 15; -fx-background-radius: 5;" text="🔄 Refresh" />
                    </HBox>
                    
                    <TableView fx:id="purchasesTable" prefHeight="300" style="-fx-background-color: #ecf0f1; -fx-control-inner-background: white;">
                        <columns>
                            <TableColumn fx:id="cityCol" prefWidth="180" text="City" />
                            <TableColumn fx:id="typeCol" prefWidth="120" text="Type" />
                            <TableColumn fx:id="priceCol" prefWidth="100" text="Price" />
                            <TableColumn fx:id="dateCol" prefWidth="150" text="Date" />
                            <TableColumn fx:id="statusCol" prefWidth="100" text="Status" />
                            <TableColumn fx:id="expiryCol" prefWidth="120" text="Expires" />
                            <TableColumn fx:id="actionCol" prefWidth="100" text="Action" />
                        </columns>
                        <placeholder>
                            <Label style="-fx-text-fill: #7f8c8d;" text="No purchases yet. Start exploring cities!" />
                        </placeholder>
                    </TableView>
                </VBox>
                
            </VBox>
        </ScrollPane>
        </HBox>
    </center>
    
    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #ecf0f1; -fx-padding: 10;">
            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="GCM Profile" />
            <Label style="-fx-text-fill: #7f8c8d;" text="•" />
            <Label fx:id="connectionLabel" style="-fx-text-fill: #27ae60; -fx-font-size: 11px;" text="Connected" />
        </HBox>
    </bottom>
</BorderPane>
