<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.effect.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.boundary.EditApprovalScreen"
            stylesheets="@sidebar.css @../styles/modern.css">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 20; -fx-border-color: #e7e7e7; -fx-border-width: 0 0 1 0;">
            <Button fx:id="backBtn" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 10; -fx-padding: 6 10;" text="← Back" />
            <Button onAction="#toggleGuestDashboard" style="-fx-background-color: #d5ed9f; -fx-text-fill: #00712d; -fx-font-family: 'Segoe UI', 'Trebuchet MS', sans-serif; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 6 14; -fx-cursor: hand;" text="Menu" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="pendingCountLabel" text="0 pending" style="-fx-text-fill: #667eea; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #888; -fx-font-size: 13px;"/>
            <HBox alignment="CENTER_RIGHT" spacing="8">
                <WebView fx:id="navbarLogoView1" contextMenuEnabled="false" maxHeight="30" maxWidth="30" minHeight="30" minWidth="30" prefHeight="30" prefWidth="30" />
                <Label style="-fx-text-fill: black; -fx-font-family: 'Trebuchet MS', 'Segoe UI', sans-serif; -fx-font-size: 24px; -fx-font-weight: bold;" text="Global City Map" />
            </HBox>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <HBox spacing="0" style="-fx-background-color: #f5f6fa;">
            <VBox fx:id="guestDashboardPane" managed="false" maxWidth="260" prefWidth="260" spacing="0" style="-fx-background-color: white; -fx-border-color: #e3e3e3; -fx-border-width: 0 1 0 0;" visible="false">
                <VBox spacing="0" style="-fx-padding: 8 0;">
                    <Button styleClass="sidebar-nav-btn" text="Browse Catalog" onAction="#openSearchScreenFromAction" maxWidth="1.7976931348623157E308"/>
                    <Button fx:id="mapEditorNavBtn" styleClass="sidebar-nav-btn" text="Map Editor" onAction="#openMapEditorFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="myPurchasesNavBtn" styleClass="sidebar-nav-btn" text="My Purchases" onAction="#openMyPurchasesFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="profileNavBtn" styleClass="sidebar-nav-btn" text="My Profile" onAction="#openProfileFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="customersNavBtn" styleClass="sidebar-nav-btn" text="Customers" onAction="#openAdminCustomersFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="pricingNavBtn" styleClass="sidebar-nav-btn" text="Pricing" onAction="#openPricingFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="pricingApprovalNavBtn" styleClass="sidebar-nav-btn" text="Approve Prices" onAction="#openPricingApprovalFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="supportNavBtn" styleClass="sidebar-nav-btn" text="Support" onAction="#openSupportFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="agentConsoleNavBtn" styleClass="sidebar-nav-btn" text="Agent Console" onAction="#openAgentConsoleFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="editApprovalsNavBtn" styleClass="sidebar-nav-btn" text="Edit Approvals" onAction="#openEditApprovalsFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="reportsNavBtn" styleClass="sidebar-nav-btn" text="City Reports" onAction="#openReportsFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    <Button fx:id="userManagementNavBtn" styleClass="sidebar-nav-btn" text="User Management" onAction="#openUserManagementFromMenu" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                </VBox>
            </VBox>
            <HBox spacing="25" style="-fx-padding: 25;" HBox.hgrow="ALWAYS">
            
            <!-- Left: Pending Requests Table -->
            <VBox spacing="15" HBox.hgrow="ALWAYS" 
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="📋 Pending Edit Requests" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🔄 Refresh" onAction="#refreshRequests"
                            style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-weight: bold;"/>
                </HBox>
                
                <TableView fx:id="versionsTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10;">
                    <columns>
                        <TableColumn fx:id="mapNameCol" text="Map Name" prefWidth="180"/>
                        <TableColumn fx:id="cityNameCol" text="City" prefWidth="120"/>
                        <TableColumn fx:id="editorCol" text="Editor" prefWidth="110"/>
                        <TableColumn fx:id="versionCol" text="Version" prefWidth="70"/>
                        <TableColumn fx:id="dateCol" text="Submitted" prefWidth="110"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="10">
                            <Label text="✨" style="-fx-font-size: 48px;"/>
                            <Label text="No pending edit requests" style="-fx-text-fill: #95a5a6; -fx-font-size: 14px;"/>
                            <Label text="All map edits have been reviewed" style="-fx-text-fill: #bdc3c7; -fx-font-size: 12px;"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- Right: Request Details Panel -->
            <VBox spacing="20" prefWidth="420" 
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0, 0, 4);">
                <Label text="📄 Edit Details" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
                
                <!-- Map Info Card -->
                <VBox spacing="10" style="-fx-background-color: linear-gradient(to right, #667eea15, #764ba215); -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #667eea30; -fx-border-radius: 12;">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS" spacing="4">
                            <Label text="Map:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                            <Label fx:id="detailMapLabel" text="(Select a request)" 
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
                        </VBox>
                        <VBox alignment="CENTER_RIGHT" spacing="4">
                            <Label text="City:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                            <Label fx:id="detailCityLabel" text="-" 
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Version Badge -->
                <HBox alignment="CENTER" spacing="15">
                    <VBox alignment="CENTER" spacing="5" 
                          style="-fx-background-color: #e8f4fd; -fx-background-radius: 12; -fx-padding: 15 25;">
                        <Label text="Version" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        <Label fx:id="detailVersionLabel" text="v-" 
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="5" 
                          style="-fx-background-color: #fef3e2; -fx-background-radius: 12; -fx-padding: 15 25;">
                        <Label text="Status" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        <Label fx:id="detailStatusLabel" text="PENDING" 
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                    </VBox>
                </HBox>

                <!-- Submitter Info -->
                <HBox spacing="15" alignment="CENTER_LEFT" 
                      style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-padding: 12;">
                    <Label text="👤" style="-fx-font-size: 20px;"/>
                    <VBox spacing="2">
                        <Label text="Submitted by:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        <Label fx:id="detailEditorLabel" text="-" 
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox spacing="2" alignment="CENTER_RIGHT">
                        <Label text="Date:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        <Label fx:id="detailDateLabel" text="-" 
                               style="-fx-font-size: 13px; -fx-text-fill: #2d3436;"/>
                    </VBox>
                </HBox>

                <!-- Changes Description -->
                <VBox spacing="8" VBox.vgrow="ALWAYS">
                    <Label text="📝 Changes Description:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                    <TextArea fx:id="detailChangesArea" editable="false" wrapText="true"
                              VBox.vgrow="ALWAYS" promptText="Select a request to see changes..."
                              style="-fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Action Buttons -->
                <HBox spacing="15">
                    <Button fx:id="approveBtn" text="✓ Approve" onAction="#handleApprove"
                            HBox.hgrow="ALWAYS" prefWidth="180" disable="true"
                            style="-fx-background-color: linear-gradient(to right, #27ae60, #2ecc71); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 15; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    <Button fx:id="rejectBtn" text="✗ Reject with Note" onAction="#handleReject"
                            HBox.hgrow="ALWAYS" prefWidth="180" disable="true"
                            style="-fx-background-color: linear-gradient(to right, #e74c3c, #c0392b); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 15; -fx-background-radius: 10; -fx-cursor: hand;"/>
                </HBox>

                <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" wrapText="true"/>
            </VBox>
            </HBox>
        </HBox>
    </center>

</BorderPane>
