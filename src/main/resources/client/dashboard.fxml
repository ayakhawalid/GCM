<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.boundary.DashboardScreen"
            style="-fx-background-color: #f5f6fa;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-padding: 14 20; -fx-border-color: #e7e7e7; -fx-border-width: 0 0 1 0;">
            <Button fx:id="logoutBtn" text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #111111; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 10; -fx-padding: 6 10;"/>
            <Button text="Menu" onAction="#toggleGuestDashboard"
                    style="-fx-background-color: #d5ed9f; -fx-text-fill: #00712d; -fx-font-family: 'Segoe UI', 'Trebuchet MS', sans-serif; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 6 14; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="2" style="-fx-cursor: hand;" onMouseClicked="#openNotifications">
                <Label text="🔔" style="-fx-font-size: 18px;"/>
                <Label fx:id="notificationBadge" text=""
                       style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 1 5; -fx-background-radius: 8; -fx-translate-x: -8; -fx-translate-y: -6;"/>
            </HBox>
            <Button text="+" onAction="#zoomInGuestMap"
                    style="-fx-background-color: #f2f7e7; -fx-text-fill: #00712d; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 3 12; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="-" onAction="#zoomOutGuestMap"
                    style="-fx-background-color: #f2f7e7; -fx-text-fill: #00712d; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 3 13; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <HBox alignment="CENTER_RIGHT" spacing="8">
                <WebView fx:id="navbarLogoView" prefWidth="30" prefHeight="30" minWidth="30" minHeight="30" maxWidth="30" maxHeight="30" contextMenuEnabled="false"/>
                <Label text="Global City Map" style="-fx-text-fill: black; -fx-font-family: 'Trebuchet MS', 'Segoe UI', sans-serif; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <HBox spacing="0">
            <!-- Sidebar Menu -->
            <VBox fx:id="guestDashboardPane" managed="false" minWidth="260" maxWidth="260" prefWidth="260" spacing="0"
                  style="-fx-background-color: white; -fx-border-color: #e3e3e3; -fx-border-width: 0 1 0 0;"
                  visible="false">
                <VBox spacing="0" style="-fx-padding: 8 0;">
                    <Button text="Browse Catalog" onAction="#openSearchScreenFromAction"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="mapEditorNavBtn" text="Map Editor" onAction="#openMapEditorFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="myPurchasesNavBtn" text="My Purchases" onAction="#openMyPurchasesFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="profileNavBtn" text="My Profile" onAction="#openProfileFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="customersNavBtn" text="Customers" onAction="#openAdminCustomersFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="pricingNavBtn" text="Pricing" onAction="#openPricingFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="pricingApprovalNavBtn" text="Approve Prices" onAction="#openPricingApprovalFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="supportNavBtn" text="Support" onAction="#openSupportFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="agentConsoleNavBtn" text="Agent Console" onAction="#openAgentConsoleFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="editApprovalsNavBtn" text="Edit Approvals" onAction="#openEditApprovalsFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="reportsNavBtn" text="City Reports" onAction="#openReportsFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                    <Button fx:id="userManagementNavBtn" text="User Management" onAction="#openUserManagementFromMenu"
                            maxWidth="1.7976931348623157E308" visible="false" managed="false"
                            style="-fx-background-color: white; -fx-text-fill: #00712d; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 14; -fx-cursor: hand; -fx-alignment: center-left;"/>
                </VBox>
            </VBox>

            <!-- Map Background -->
            <AnchorPane fx:id="guestMapAnchorPane" style="-fx-background-color: white;" HBox.hgrow="ALWAYS"/>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #ecf0f1; -fx-padding: 10;">
            <Label text="GCM System v2.0" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
            <Label text="•" style="-fx-text-fill: #7f8c8d;"/>
            <Label fx:id="statusLabel" text="Connected to server" style="-fx-text-fill: #27ae60; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>
</BorderPane>
